<Window x:Class="OrisTpsWriter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ORIS TPS Writer — ქართული ბუღალტრული ცხრილების გენერატორი"
        Height="860" Width="1160"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI, BPG Nino Mtavruli, Sylfaen"
        Background="#F4F5F7">

    <Window.Resources>
        <SolidColorBrush x:Key="Ink"      Color="#1C2530"/>
        <SolidColorBrush x:Key="Muted"    Color="#6A7480"/>
        <SolidColorBrush x:Key="Accent"   Color="#2D6A4F"/>
        <SolidColorBrush x:Key="AccentDk" Color="#1B4332"/>
        <SolidColorBrush x:Key="Line"     Color="#DCE0E6"/>
        <SolidColorBrush x:Key="Panel"    Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Danger"   Color="#B23A48"/>

        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Background"       Value="{StaticResource Accent}"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Padding"          Value="14,8"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource AccentDk}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Background" Value="#B8C0C8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnGhost" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#EAEDF0"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}"
                                BorderBrush="{StaticResource Line}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#DDE2E7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="{StaticResource Danger}"/>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"       Value="{StaticResource Panel}"/>
            <Setter Property="CornerRadius"     Value="10"/>
            <Setter Property="BorderBrush"      Value="{StaticResource Line}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="16"/>
        </Style>

        <Style x:Key="H2" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="14"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Foreground"   Value="{StaticResource Ink}"/>
            <Setter Property="Margin"       Value="0,0,0,10"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding"          Value="7,5"/>
            <Setter Property="BorderBrush"      Value="{StaticResource Line}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="FontSize"         Value="13"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding"   Value="7,5"/>
            <Setter Property="FontSize"  Value="13"/>
        </Style>

        <!-- Tab header style -->
        <Style x:Key="TabHdr" TargetType="TabItem">
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Padding"     Value="18,10"/>
            <Setter Property="Foreground"  Value="{StaticResource Muted}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource AccentDk}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- სათაური -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="ORIS TPS Writer" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource AccentDk}"/>
            <TextBlock Text="ქართული ბუღალტრული .tps ფაილების გენერატორი — Clarion TopSpeed თავსებადი"
                       FontSize="13" Foreground="{StaticResource Muted}" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- ===================== TAB CONTROL ===================== -->
        <TabControl Grid.Row="1" x:Name="TabMain" Background="Transparent" BorderThickness="0,1,0,0"
                    BorderBrush="{StaticResource Line}">

            <!-- ══════════════════════════════════════════════════
                 TAB 1 — TPS READER
            ══════════════════════════════════════════════════════ -->
            <TabItem Header="📖   TPS Reader" Style="{StaticResource TabHdr}">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- 0: file / font / convert -->
                        <RowDefinition Height="Auto"/>  <!-- 1: CRUD action bar -->
                        <RowDefinition Height="*"/>     <!-- 2: DataGrid -->
                        <RowDefinition Height="Auto"/>  <!-- 3: Edit panel (collapsed) -->
                        <RowDefinition Height="Auto"/>  <!-- 4: status -->
                    </Grid.RowDefinitions>

                    <!-- Row 0 — Controls bar -->
                    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,8" Padding="14,10">
                        <WrapPanel VerticalAlignment="Center">
                            <Button x:Name="BtnOpenTps" Content="📂  ფაილის არჩევა"
                                    Style="{StaticResource Btn}" Click="BtnOpenTps_Click"/>
                            <TextBlock x:Name="TxtOpenedFile" Text="ფაილი არ არის არჩეული"
                                       Foreground="{StaticResource Muted}" VerticalAlignment="Center"
                                       FontSize="12" Margin="12,0,18,0" MaxWidth="280"
                                       TextTrimming="CharacterEllipsis"/>
                            <Rectangle Width="1" Height="22" Fill="{StaticResource Line}" Margin="0,0,14,0"/>
                            <TextBlock Text="ფონტი:" VerticalAlignment="Center"
                                       Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,6,0"/>
                            <ComboBox x:Name="CmbReaderFont" Width="190" VerticalAlignment="Center"
                                      SelectionChanged="CmbReaderFont_SelectionChanged"/>
                            <Button x:Name="BtnConvert" Content="🔤  კონვერტაცია"
                                    Style="{StaticResource BtnGhost}"
                                    Margin="10,0,0,0" MinWidth="160"
                                    Click="BtnConvert_Click"/>
                        </WrapPanel>
                    </Border>

                    <!-- Row 1 — CRUD action bar (enabled after file load) -->
                    <Border Grid.Row="1" x:Name="CrudBar" Style="{StaticResource Card}"
                            Margin="0,0,0,8" Padding="12,8" IsEnabled="False" Opacity="0.55">
                        <DockPanel>
                            <TextBlock Text="ჩანაწერების რედაქტირება:"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource Ink}"
                                       VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                <Button x:Name="BtnInsert" Content="➕  INSERT"
                                        Style="{StaticResource Btn}" Click="BtnInsert_Click"/>
                                <Button x:Name="BtnUpdate" Content="✏️  UPDATE"
                                        Style="{StaticResource BtnGhost}" Margin="6,0,0,0"
                                        Click="BtnUpdate_Click"/>
                                <Button x:Name="BtnDelete" Content="🗑️  DELETE"
                                        Style="{StaticResource BtnDanger}" Margin="6,0,0,0"
                                        Click="BtnDelete_Click"/>
                            </StackPanel>
                            <Button x:Name="BtnSaveTps" Content="💾  TPS-ში შენახვა"
                                    Style="{StaticResource Btn}" HorizontalAlignment="Right"
                                    FontWeight="SemiBold" Click="BtnSaveTps_Click"/>
                        </DockPanel>
                    </Border>

                    <!-- Row 2 — DataGrid -->
                    <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
                        <DataGrid x:Name="GridReader"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="All" GridLinesVisibility="All"
                                  BorderThickness="0" RowBackground="White"
                                  AlternatingRowBackground="#F7F9FA" FontSize="13"
                                  HorizontalScrollBarVisibility="Auto"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"/>
                    </Border>

                    <!-- Row 3 — Edit panel (INSERT / UPDATE form, collapsed by default) -->
                    <Border Grid.Row="3" x:Name="EditPanel" Style="{StaticResource Card}"
                            Margin="0,8,0,0" Visibility="Collapsed" MaxHeight="320">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                                <TextBlock x:Name="TxtEditPanelTitle" Text="ახალი ჩანაწერი"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource Ink}" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="✓  შენახვა" Style="{StaticResource Btn}"
                                            Click="BtnEditOk_Click"/>
                                    <Button Content="✗  გაუქმება" Style="{StaticResource BtnGhost}"
                                            Margin="6,0,0,0" Click="BtnEditCancel_Click"/>
                                </StackPanel>
                            </Grid>
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <WrapPanel x:Name="EditFieldsPanel" Orientation="Horizontal"/>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- Row 4 — Status -->
                    <Border Grid.Row="4" Style="{StaticResource Card}" Margin="0,8,0,0" Padding="14,10">
                        <TextBlock x:Name="TxtReaderStatus"
                                   Text="ფაილი არ არის ჩატვირთული."
                                   Foreground="{StaticResource Muted}" FontSize="12"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ══════════════════════════════════════════════════
                 TAB 2 — TPS WRITER
            ══════════════════════════════════════════════════════ -->
            <TabItem Header="✏️   TPS Writer" Style="{StaticResource TabHdr}">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ფილდები + Keys -->
                    <Grid Grid.Row="0" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="1.4*"/>
                        </Grid.ColumnDefinitions>

                        <!-- მარცხენა: ცხრილი + ფილდი -->
                        <Border Grid.Column="0" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="ცხრილის კონფიგურაცია" Style="{StaticResource H2}"/>
                                <TextBlock Text="ცხრილის სახელი" FontSize="12" Foreground="{StaticResource Muted}"/>
                                <TextBox x:Name="TxtTableName" Text="UNNAMED" Margin="0,3,0,12"/>
                                <Separator Margin="0,0,0,12" Background="{StaticResource Line}"/>
                                <TextBlock Text="ახალი ფილდი" FontSize="12" Foreground="{StaticResource Muted}" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtFieldName" Grid.Column="0"/>
                                    <ComboBox x:Name="CmbFieldType" Grid.Column="2" Width="110" SelectedIndex="0">
                                        <ComboBoxItem Content="STRING"/>
                                        <ComboBoxItem Content="LONG"/>
                                        <ComboBoxItem Content="ULONG"/>
                                        <ComboBoxItem Content="SHORT"/>
                                    </ComboBox>
                                </Grid>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="სიგრძე:" VerticalAlignment="Center"
                                               FontSize="12" Foreground="{StaticResource Muted}"/>
                                    <TextBox x:Name="TxtFieldLen" Grid.Column="2" Text="30"/>
                                    <Button x:Name="BtnAddField" Grid.Column="4" Content="+ დამატება"
                                            Style="{StaticResource Btn}" Click="BtnAddField_Click"/>
                                </Grid>
                                <TextBlock Text="ფილდები" FontSize="12" Foreground="{StaticResource Muted}" Margin="0,14,0,4"/>
                                <ListView x:Name="LstFields" Height="150" BorderBrush="{StaticResource Line}">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="#"       Width="30"  DisplayMemberBinding="{Binding Seq}"/>
                                            <GridViewColumn Header="სახელი"  Width="150" DisplayMemberBinding="{Binding Name}"/>
                                            <GridViewColumn Header="ტიპი"   Width="70"  DisplayMemberBinding="{Binding TypeName}"/>
                                            <GridViewColumn Header="სიგრძე" Width="55"  DisplayMemberBinding="{Binding Length}"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                                <Button x:Name="BtnRemoveField" Content="მონიშნულის წაშლა"
                                        Style="{StaticResource BtnGhost}" HorizontalAlignment="Left"
                                        Margin="0,6,0,0" Click="BtnRemoveField_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- მარჯვენა: Keys -->
                        <Border Grid.Column="2" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Keys (ინდექსები)" Style="{StaticResource H2}"/>
                                <TextBlock Text="Clarion-ი მოითხოვს მინიმუმ ერთ key-ს ჩანაწერების საჩვენებლად."
                                           FontSize="11" Foreground="{StaticResource Muted}"
                                           TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtKeyName" Grid.Column="0"/>
                                    <Button x:Name="BtnAddKey" Grid.Column="2" Content="+ key"
                                            Style="{StaticResource Btn}" Click="BtnAddKey_Click"/>
                                </Grid>
                                <TextBlock Text="key-ის ფილდები (მონიშნე ქვემოთ):" FontSize="11"
                                           Foreground="{StaticResource Muted}" Margin="0,8,0,4"/>
                                <ListView x:Name="LstKeyFields" Height="80" SelectionMode="Multiple"
                                          BorderBrush="{StaticResource Line}">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="ფილდი" Width="200"
                                                DisplayMemberBinding="{Binding Name}"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                                <TextBlock Text="დამატებული keys:" FontSize="11"
                                           Foreground="{StaticResource Muted}" Margin="0,10,0,4"/>
                                <ListBox x:Name="LstKeys" Height="90" BorderBrush="{StaticResource Line}" FontSize="12"/>
                                <Button x:Name="BtnRemoveKey" Content="მონიშნული key-ის წაშლა"
                                        Style="{StaticResource BtnGhost}" HorizontalAlignment="Left"
                                        Margin="0,6,0,0" Click="BtnRemoveKey_Click"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- მონაცემთა ცხრილი -->
                    <Border Grid.Row="1" Style="{StaticResource Card}">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                                <TextBlock Text="მონაცემები (ჩანაწერები)" Style="{StaticResource H2}"
                                           VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="BtnDemo" Content="Demo მონაცემები"
                                            Style="{StaticResource BtnGhost}" Click="BtnDemo_Click"/>
                                    <Button x:Name="BtnAddRow" Content="+ ჩანაწერი"
                                            Style="{StaticResource Btn}" Margin="6,0,0,0" Click="BtnAddRow_Click"/>
                                    <Button x:Name="BtnDelRow" Content="რიგის წაშლა"
                                            Style="{StaticResource BtnGhost}" Margin="6,0,0,0" Click="BtnDelRow_Click"/>
                                    <Button x:Name="BtnImportCsv" Content="CSV იმპორტი"
                                            Style="{StaticResource BtnGhost}" Margin="6,0,0,0" Click="BtnImportCsv_Click"/>
                                    <Button x:Name="BtnImportExcel" Content="Excel იმპორტი"
                                            Style="{StaticResource BtnGhost}" Margin="6,0,0,0" Click="BtnImportExcel_Click"/>
                                </StackPanel>
                            </Grid>
                            <DataGrid x:Name="GridData" AutoGenerateColumns="False"
                                      CanUserAddRows="True" CanUserDeleteRows="True"
                                      HeadersVisibility="All" GridLinesVisibility="All"
                                      BorderBrush="{StaticResource Line}"
                                      RowBackground="White" AlternatingRowBackground="#F7F9FA" FontSize="13"/>
                        </DockPanel>
                    </Border>

                    <!-- ქვედა პანელი -->
                    <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,14,0,0" Padding="14,12">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtStatus" Text="მზადაა."
                                           Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="BtnPreview" Content="სტრუქტურის გადახედვა"
                                        Style="{StaticResource BtnGhost}" Click="BtnPreview_Click"/>
                                <Button x:Name="BtnSave" Content="💾  .tps ფაილის შენახვა"
                                        Style="{StaticResource Btn}" Margin="8,0,0,0"
                                        FontWeight="SemiBold" Click="BtnSave_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ══════════════════════════════════════════════════
                 TAB 3 — MULTI EXPORT
            ══════════════════════════════════════════════════════ -->
            <TabItem Header="📊   Multi Export" Style="{StaticResource TabHdr}">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- header info -->
                    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,10" Padding="14,10">
                        <Grid>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="მრავალი TPS ფაილის Excel-ში ექსპორტი"
                                           FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/>
                                <TextBlock Text="დაამატე .tps ფაილები, მონიშნე სასურველი და ექსპორტი გააკეთე — თითოეული ფაილი ცალკე შიტზე მოხვდება."
                                           FontSize="12" Foreground="{StaticResource Muted}" Margin="0,3,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Content="+ ფაილების დამატება" Style="{StaticResource Btn}"
                                        Click="BtnAddExportFiles_Click"/>
                                <Button Content="ყველას მონიშვნა" Style="{StaticResource BtnGhost}"
                                        Margin="6,0,0,0" Click="BtnSelectAllExport_Click"/>
                                <Button Content="ყველას გაუქმება" Style="{StaticResource BtnGhost}"
                                        Margin="6,0,0,0" Click="BtnDeselectAllExport_Click"/>
                                <Button Content="მონიშნულის წაშლა" Style="{StaticResource BtnGhost}"
                                        Margin="6,0,0,0" Click="BtnRemoveExportFile_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- File list -->
                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                        <DataGrid x:Name="GridExport"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  HeadersVisibility="All" GridLinesVisibility="All"
                                  BorderThickness="0" RowBackground="White"
                                  AlternatingRowBackground="#F7F9FA" FontSize="13"
                                  SelectionMode="Extended">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="✓" Width="46" CanUserSort="False" CanUserResize="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="ფაილი"    Binding="{Binding FileName}" Width="220" IsReadOnly="True"/>
                                <DataGridTextColumn Header="სრული გზა" Binding="{Binding FullPath}" Width="*"   IsReadOnly="True"/>
                                <DataGridTextColumn Header="სტატუსი"  Binding="{Binding Status}"   Width="160" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Export bottom bar -->
                    <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,10,0,0" Padding="14,12">
                        <Grid>
                            <TextBlock x:Name="TxtExportStatus" Text="ფაილები არ არის დამატებული."
                                       Foreground="{StaticResource Muted}" VerticalAlignment="Center" FontSize="12"/>
                            <Button Content="📊  Excel-ში ექსპორტი"
                                    Style="{StaticResource Btn}" HorizontalAlignment="Right"
                                    FontWeight="SemiBold" Click="BtnExportMulti_Click"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
